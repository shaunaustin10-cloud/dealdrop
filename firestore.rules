rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Marketplace Deals Collection ---
    match /artifacts/{appId}/publicDeals/{dealId} {
      allow read: if true; // Publicly readable
      allow create: if request.auth != null; // Allow any logged in user to post
      
      // Allow specific partial updates for social/gatekeeper features
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'savedBy', 'unlockedBy']) ||
        request.auth.uid == resource.data.sellerId || 
        get(/databases/$(database)/documents/artifacts/$(appId)/profiles/$(request.auth.uid)).data.role == 'admin'
      );
      
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.sellerId || 
        get(/databases/$(database)/documents/artifacts/$(appId)/profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // --- Foreclosure Leads Collection ---
    match /artifacts/{appId}/foreclosureLeads/{leadId} {
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/artifacts/$(appId)/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- User Profiles Collection ---
    match /artifacts/{appId}/profiles/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // --- Inquiries Subcollection ---
    match /artifacts/{appId}/users/{userId}/inquiries/{inquiryId} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- Private Deals Collection ---
    match /artifacts/{appId}/users/{userId}/deals/{dealId} {
      allow read: if request.auth.uid == userId || resource.data.shareable == true || resource.data.publiclyVisible == true;
      allow write: if request.auth.uid == userId;
    }

    // Support collectionGroup queries for shared deals
    match /{path=**}/deals/{dealId} {
      allow read: if resource.data.shareable == true || (request.auth != null && request.auth.uid == resource.data.createdBy);
    }
    
    // --- Property Cache Collection ---
    match /property_cache/{cacheId} {
      allow read, write: if isAuthenticated();
    }
    
    // --- Platform Stats ---
    match /artifacts/{appId}/stats/{statId} {
      allow read: if true;
    }
    
    // --- Stripe Extensions Collections ---
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;
      match /checkout_sessions/{id} { allow read, write: if request.auth.uid == uid; }
      match /subscriptions/{id} { allow read: if request.auth.uid == uid; }
      match /payments/{id} { allow read: if request.auth.uid == uid; }
    }

    match /products/{id} {
      allow read: if true;
      match /prices/{id} { allow read: if true; }
      match /tax_rates/{id} { allow read: if true; }
    }
  }
}