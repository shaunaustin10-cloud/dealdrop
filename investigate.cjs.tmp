admin.initializeApp({
  credential: admin.credential.cert(sa),
  projectId: sa.project_id
});

const db = admin.firestore();
const auth = admin.auth();

async function run() {
  try {
    const user = await auth.getUserByEmail('test@gmail.com');
    console.log(`UID: ${user.uid}`);
    
    // Check ALL artifacts
    const collections = ['default-app-id', 'default-app-id', 'web-app-30504'];
    for (const id of collections) {
      console.log(`\n--- Checking ID: ${id} ---`);
      const profile = await db.collection('artifacts').doc(id).collection('profiles').doc(user.uid).get();
      if (profile.exists()) {
        console.log(`Profile:`, JSON.stringify(profile.data()));
      }
      const deals = await db.collection('artifacts').doc(id).collection('users').doc(user.uid).collection('deals').get();
      console.log(`Deals: ${deals.size}`);
    }
  } catch (e) {
    console.error(e);
  }
}
run();
